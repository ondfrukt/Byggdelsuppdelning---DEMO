  "relation_types": [
    {
      "key": "applies_to",
      "display_name": "Applies To",
      "description": "Used when source represents a requirement, rule, instruction, or other governing information that applies to target. Source can apply to multiple targets, and targets can be covered by multiple requirements or instructions. Typical examples: Requirement applies to Building Part, Instruction applies to Module, Rule applies to System.",
      "source_object_type": null,
      "target_object_type": null,
      "cardinality": "many_to_many",
      "is_directed": true,
      "is_composition": false,
      "inverse_key": null
    },
    {
      "key": "connects_to",
      "display_name": "Connects To",
      "description": "Used when two objects are connected through a physical or logical connection or interface. The relation describes a network/graph rather than a hierarchy. Neither party owns the other through this relation. Typical examples: Building Part connects to Building Part, System connects to System, Object is connected to another object via connection.",
      "source_object_type": null,
      "target_object_type": null,
      "cardinality": "many_to_many",
      "is_directed": false,
      "is_composition": false,
      "inverse_key": null
    },
    {
      "key": "contains",
      "display_name": "Contains",
      "description": "Used when target is a structural part of source and is included in its internal composition. This describes a hierarchical relation where target normally does not exist as part of multiple parents simultaneously. Typical examples: Technical description contains technical chapter, File Object contains file.",
      "source_object_type": null,
      "target_object_type": null,
      "cardinality": "one_to_many",
      "is_directed": true,
      "is_composition": true,
      "inverse_key": null
    },
    {
      "key": "references_object",
      "display_name": "References",
      "description": "Used when source references target as information, documentation, a related entity, or classification, without target being a physical part of source. The relation represents traceability or context, not use or ownership. Typical examples: Product references File Object, Building Part references Document, Object references System.",
      "source_object_type": null,
      "target_object_type": null,
      "cardinality": "many_to_many",
      "is_directed": true,
      "is_composition": false,
      "inverse_key": null
    },
    {
      "key": "uses_object",
      "display_name": "Uses",
      "description": "Used when source uses, includes, or otherwise leverages target as part of its solution. Target is reusable and not owned by source. Target can be used by multiple objects at the same time. Typical examples: Building Part uses Product, Module uses Product, Connection uses Product.",
      "source_object_type": null,
      "target_object_type": null,
      "cardinality": "many_to_many",
      "is_directed": true,
      "is_composition": false,
      "inverse_key": null
    }
  ],
